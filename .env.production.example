# Production env contract for the VPS — copy to /opt/techstore/.env and fill in.
# docker-compose.prod.yml loads this via `env_file: .env` for the api and web services.
# Only the variables below are REQUIRED; everything else has a safe default in
# apps/api/src/modules/config/env.schema.ts.

# ── Database ──────────────────────────────────────────────────────────────────
# POSTGRES_PASSWORD is consumed by the db service AND must match the one in DATABASE_URL.
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
# Inside the compose network the db host is the service name `db` on port 5432.
DATABASE_URL=postgresql://techstore:CHANGE_ME_strong_db_password@db:5432/techstore

# ── Auth (REQUIRED, each ≥ 32 chars) ──────────────────────────────────────────
# Generate with: openssl rand -base64 36
JWT_ACCESS_SECRET=CHANGE_ME_at_least_32_characters_long
JWT_REFRESH_SECRET=CHANGE_ME_at_least_32_characters_long

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
# Public URLs (used for CORS + the web bundle). Set to your real domain.
WEB_URL=https://techstore.yourdomain.com
API_URL=https://techstore.yourdomain.com/api

# ── Optional integrations (leave blank to disable) ────────────────────────────
# SMTP_HOST=
# SMTP_USER=
# SMTP_PASS=
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ADMIN_CHAT_ID=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=https://techstore.yourdomain.com/api/auth/google/callback
# MINIO_ENDPOINT=
# MINIO_ACCESS_KEY=
# MINIO_SECRET_KEY=
# MINIO_BUCKET=techstore
# MINIO_PUBLIC_URL=

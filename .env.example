# Copy this file to .env and fill in your values.
# Never commit the real .env — it is git-ignored.

# ── Database ──────────────────────────────────────────────────────────────────
# Local Postgres (default): postgresql://postgres:<password>@localhost:5432/techstore
# Docker Postgres:          postgresql://techstore:<password>@localhost:5433/techstore
DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/techstore
POSTGRES_PASSWORD=CHANGE_ME

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 36   (must be ≥ 32 chars)
JWT_ACCESS_SECRET=change_me_at_least_32_chars_long_access_secret
JWT_REFRESH_SECRET=change_me_at_least_32_chars_long_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ── Seed owner account ────────────────────────────────────────────────────────
# Used by packages/db/prisma/seed.ts (dev/test only — never runs in production)
SEED_OWNER_EMAIL=owner@example.com
SEED_OWNER_PASSWORD=ChangeMeStrong1!
SEED_OWNER_NAME=Store Owner

# ── Email / SMTP (optional — needed for OTP verification & password reset) ────
# Gmail: enable 2FA, then generate an App Password at myaccount.google.com/apppasswords
# Leave blank to disable email — users won't be able to verify accounts or reset passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=TechStore <noreply@techstore.uz>

# ── Telegram (optional) ───────────────────────────────────────────────────────
# Leave blank to disable the Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# ── Google OAuth (optional) ───────────────────────────────────────────────────
# Get credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI to add: http://localhost:4000/api/auth/google/callback
# Leave blank to disable Google login
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# ── Payments (optional — sandbox values are fine for dev) ─────────────────────
PAYME_MERCHANT_ID=
PAYME_KEY=
CLICK_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_SECRET=

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=4000
WEB_URL=http://localhost:3000
API_URL=http://localhost:4000
UPLOAD_DIR=./uploads
